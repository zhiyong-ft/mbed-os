{
  name: "rtt",
  config: {
    "ch0-up-buffer-size": {
      help: "Size in bytes of channel 0 up buffer (the one used for stdout).",
      value: 1024
    },
    "ch0-down-buffer-size": {
      help: "Size in bytes of channel 0 down buffer (the one used for stdin).",
      value: 16
    },
    "max-channels": {
      help: "Maximum number of channels supported by RTT. This controls the size of some static arrays within the RTT code. Note that this does NOT, by itself, allocate space for the buffers.",
      value: 3
    }
  }
}