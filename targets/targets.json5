	// These targets contain the extra bits to add to the MCU_STM32H745xI target to set it for the
	// CM4 or CM7 core.
    "MCU_STM32H745xI_CM4": {
        "public": false,
        "extra_labels_add": [
            "STM32H745xI_CM4"
        ],
        "core": "Cortex-M4F",
        "memory_bank_config": {
            // Select flash bank 2
            "IROM1": {
                "start": 0x08100000,
                "size": 0x100000
            }
        },
        "macros_add": [
            "CORE_CM4"
        ]
    },
    "MCU_STM32H745xI_CM7": {
        "public": false,
        "extra_labels_add": [
            "STM32H745xI_CM7"
        ],
        "core": "Cortex-M7FD",
        "memory_bank_config": {
            // Select flash bank 1
            "IROM1": {
                "start": 0x08000000,
                "size": 0x100000
            }
        },
        "macros_add": [
            "CORE_CM7"
        ]
    },
