            "FLASH",
            "I2C",
            "INTERRUPTIN",
            "LPTICKER",
            "PORTIN",
            "PORTINOUT",
            "PORTOUT",
            "SERIAL",
            "SLEEP",
            "SPI",
            "SPISLAVE",
            "TSC",
            "TRNG",
            "USTICKER"
        ],
        "overrides": {
            "network-default-interface-type": "ETHERNET"
        }
    },
    "FVP_MPS2_M0": {
        "inherits": [
