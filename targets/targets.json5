    "MCU_STM32H747xI_CM7": {
        "public": false,
        "extra_labels_add": [
            "STM32H747xI_CM7"
        ],
        "core": "Cortex-M7FD",
        "memory_bank_config": {
            // Select flash bank 1
            "IROM1": {
                "start": 0x08000000,
                "size": 0x100000
            }
        },
        "macros_add": [
            "CORE_CM7"
        ]
    },
    "MCU_STM32H747xI_CM4": {
