    // Target family for all Raspberry Pi RP2xxx MCUs
    "MCU_RP2": {
        "public": false,
        "inherits": ["Target"],
        "extra_labels": [
            "RASPBERRYPI",
            "memmap_default"
        ],
        "overrides": {
            "xip-enable": true,

            // ADC_VDD sets the ADC reference voltage on this chip.
            // Most RP2xxx boards set this pin to 3.3V.
            // Note that if the I/O voltage is set to less than the ADC reference voltage,
            // voltages higher than the I/O voltage are illegal for the analog pins
            // (so the ADC can never read 100%).
            "default-adc-vref": 3.3,

            "mpu-rom-end": "0x13FFFFFF", // Flash memory ends at 0x10FFFFFF, rounding up to next supported value
            "mpu-ram-start": "MBED_RAM_BANK_IRAM1_START",

            // Sleep wakeup latency, measured on hardware
            "deep-sleep-latency": 1, // ms
        },
        "device_has": [
            "ANALOGIN",
            "FLASH",
            "I2C",
            "I2CSLAVE",
            "INTERRUPTIN",
            "PWMOUT",
            "SERIAL",
            "SERIAL_FC",
            "SPI",
            "USTICKER",
            "WATCHDOG",
            "USBDEVICE",
            "RESET_REASON",
            "MPU",
            "SLEEP"
        ],
        "macros_add": [
            "PICO_TIME_DEFAULT_ALARM_POOL_DISABLED",
            "PICO_ON_DEVICE=1",
            "PICO_NO_HARDWARE=0",
            "PICO_32BIT=1",

            // Do not translate CRLF to LF in UART Pico SDK driver
            "PICO_UART_ENABLE_CRLF_SUPPORT=0"
        ]
    },

    // Target for RP2040 MCU
    "MCU_RP2040": {
        "public": false,
        "inherits": ["MCU_RP2"],
        "core": "Cortex-M0+",
        "is_mcu_family_target": true,
        "device_name": "RP2040",

        "device_has_add": [
            // Only RP2040 has a dedicated RTC, it was removed in later chips.
            // Also note that the RTC is the only LP-ticker-like feature this chip has,
            // but is unsuited to being used as an LP ticker because it only counts at 1Hz.
            // So, RP2040 does not support LPTICKER.
            "RTC",
        ],

        "macros_add": [
            "PICO_RP2040=1",
            "PICO_RP2040_USB_DEVICE_ENUMERATION_FIX=1"
        ],

        // For backwards compatibility with Mbed CE 7.0 and earlier, also make this match
        // the target label "RP2040" in addition to "MCU_RP2040".
        "extra_labels_add": [
            "RP2040",
        ]
    },

    // Target for RP235x family MCU
    "MCU_RP235X": {
        "inherits": ["MCU_RP2"],
        "core": "Cortex-M33FE",
        "is_mcu_family_target": true,
        "macros_add": [
            "PICO_RP2350=1"
        ],
        "device_has_add": [
            "LPTICKER"
        ],

        "device_has_remove": [
            "ANALOGIN",
            "PWMOUT",
            "SERIAL_FC",
            "SPI",
            "USBDEVICE",
        ],
        "config": {
            "lpticker-use-lposc": {
                "value": false,
                "help": "If left at false, the LP Ticker (which uses the POWMAN always-on timer internally) will run off the XOSC. If changed to true, the LPTICKER will run off the LPOSC. This supports deeper sleep modes but has a limited frequency accuracy of +-20% (untrimmed)."
            }
        }
    },

    // Target for RP2350 family MCU
    "MCU_RP2350": {
        "inherits": ["MCU_RP235X"],
        "device_name": "RP2350",
    },


    // Target for Raspberry Pi Pico board using the RP2040 MCU.
    // Will also work for some 3rd party compatible boards as well.
    "RASPBERRY_PI_PICO": {
        "inherits": ["MCU_RP2040"],
        "overrides": {
            // Use USB serial for the default console on this board instead of the UART
            "console-usb": true,
            "console-uart": false,
        },
        "memory_banks": {
            "QSPI_FLASH": {
                "access": {
                    "execute": true,
                    "peripheral": false,
                    "read": true,
                    "secure": false,
                    "write": false
                },
                "default": true,
                "startup": true,
                "size": 0x200000, // 2MiB
                "start": 0x10000000
            }
        },
        "image_url": "https://akizukidenshi.com/img/goods/L/116132.jpg"
    },

